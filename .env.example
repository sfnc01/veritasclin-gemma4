NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=veritasclin-field
NCBI_MAX_RPS=3

# LLM provider: ollama (Ollama Cloud or local), openai_compatible, mock (no inference)
# Set to ollama for Ollama Cloud (set OLLAMA_BASE_URL + OLLAMA_API_KEY).
# Set to mock for CI/demo without a running model.
GEMMA_PROVIDER=ollama
GEMMA_MODEL=gemma4:31b

# Ollama endpoint — cloud or local
# Cloud: OLLAMA_BASE_URL=https://ollama.com, OLLAMA_API_KEY=<key from ollama.com/settings/keys>
# Local: OLLAMA_BASE_URL=http://localhost:11434, leave OLLAMA_API_KEY empty
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=

# OpenAI-compatible endpoint (alternative to ollama provider, for other Gemma API endpoints)
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gemma4:31b

VERITASCLIN_PACK_DIR=evidence_packs
