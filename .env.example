NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=veritasclin-field
NCBI_MAX_RPS=3

# LLM provider: openai_compatible (production), ollama (local), mock (no inference)
# Set to openai_compatible for Ollama Cloud or any OpenAI-compatible Gemma endpoint.
# Set to mock for CI/demo without a running model.
GEMMA_PROVIDER=openai_compatible
GEMMA_MODEL=gemma4:e4b

# Ollama local endpoint (used when GEMMA_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible endpoint (used when GEMMA_PROVIDER=openai_compatible)
# Example: Ollama Cloud — https://ollama.com/v1
OPENAI_COMPATIBLE_BASE_URL=https://ollama.com/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gemma4:e4b

VERITASCLIN_PACK_DIR=evidence_packs
